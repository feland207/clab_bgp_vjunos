{# IOS XR BGP Global Configuration #}
{% if bgp is defined %}
router bgp {{ bgp.local_as }}
 bgp router-id {{ loopback_ipv4 | ansible.utils.ipaddr('address') }}
 address-family ipv4 unicast
 !
 
{# Build the Neighbor Groups #}
{% if bgp.groups is defined %}
{% for group in bgp.groups %}
 neighbor-group {{ group.name }}
{% if group.type == 'external' %}
  remote-as {{ group.peer_as }}
{% elif group.type == 'internal' %}
  remote-as {{ bgp.local_as }}
  update-source Loopback0
{% endif %}
  address-family ipv4 unicast
{% if group.next_hop_self | default(false) | bool %}
   next-hop-self
{% endif %}
{% if group.export_policy is defined %}
   route-policy {{ group.export_policy }} out
{% endif %}
{% if group.import_policy is defined %}
   route-policy {{ group.import_policy }} in
{% endif %}
  !
 !
{% endfor %}
{% endif %}

{# Attach Physical Peers to the Neighbor Groups #}
{% if bgp.groups is defined %}
{% for group in bgp.groups %}
{% for peer in group.peers %}
 neighbor {{ peer.ip }}
  use neighbor-group {{ group.name }}
  description {{ peer.description }}
 !
{% endfor %}
{% endfor %}
{% endif %}
!
{% endif %}