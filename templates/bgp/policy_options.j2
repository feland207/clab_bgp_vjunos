{# Configure Policy Options #}
{% if policies is defined %}
{% for policy in policies %}
{% for term in policy.terms %}

{# Only render 'from protocol' if it exists in the YAML #}
{% if term.from_protocol is defined %}
set policy-options policy-statement {{ policy.name }} term {{ term.name }} from protocol {{ term.from_protocol }}
{% endif %}

{# Only iterate through 'route_filters' if they exist in the YAML #}
{% if term.route_filters is defined %}
{% for filter in term.route_filters %}
set policy-options policy-statement {{ policy.name }} term {{ term.name }} from route-filter {{ filter }}
{% endfor %}
{% endif %}

{# Action: Local Preference #}
{% if term.local_preference is defined %}
set policy-options policy-statement {{ policy.name }} term {{ term.name }} then local-preference {{ term.local_preference }}
{% endif %}

{# Action: AS Path Prepend #}
{% if term.as_path_prepend is defined %}
set policy-options policy-statement {{ policy.name }} term {{ term.name }} then as-path-prepend "{{ term.as_path_prepend }}"
{% else %}
{# Explicitly delete it if omitted from the YAML #}
delete policy-options policy-statement {{ policy.name }} term {{ term.name }} then as-path-prepend
{% endif %}

{# The 'then' statement is always required #}
set policy-options policy-statement {{ policy.name }} term {{ term.name }} then {{ term.then }}

{% endfor %}
{% endfor %}
{% endif %}

{% for group in bgp.groups %}

{# Export Policy Handling #}
{% if group.export_policy is defined %}
set protocols bgp group {{ group.name }} export {{ group.export_policy }}
{% else %}
{# If no policy is defined, ensure any old policy is removed #}
delete protocols bgp group {{ group.name }} export
{% endif %}

{# Import Policy Handling #}
{% if group.import_policy is defined %}
set protocols bgp group {{ group.name }} import {{ group.import_policy }}
{% else %}
{# If no policy is defined, ensure any old policy is removed #}
delete protocols bgp group {{ group.name }} import
{% endif %}

{% endfor %}
