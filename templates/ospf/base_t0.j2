{# OSPF Protocol Global Settings (Cisco IOS XR) #}
router ospf 1
 router-id {{ loopback_ipv4 | ansible.utils.ipaddr('address') }}
 auto-cost reference-bandwidth 10000
 
{# The primary loopback is universally placed in Area 0 as we are focus on BGP practice #}
{# In IOS XR, loopback interfaces are considered stub networks and are passive by default #}
 area 0.0.0.0
  interface Loopback0
  !

{# Dynamically assign physical interfaces to their defined areas #}
{% if interfaces is defined %}
{% for iface in interfaces %}
{% if iface.ospf_area is defined and iface.ospf_area == '0.0.0.0' %}
  interface {{ iface.name }}
   network point-to-point
  !
{% endif %}
{% endfor %}
{% endif %}
{% if interfaces is defined %}
{% for area, iface_list in interfaces | selectattr('ospf_area', 'defined') | rejectattr('ospf_area', 'equalto', '0.0.0.0') | groupby('ospf_area') %}
 area {{ area }}
{% for iface in iface_list %}
  interface {{ iface.name }}
   network point-to-point
  !
{% endfor %}
{% endfor %}
{% endif %}
!