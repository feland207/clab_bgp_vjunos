{# Interfaces and Routing Options Template (Cisco IOS XR) #}
interface Loopback0
 ipv4 address {{ loopback_ipv4 | ansible.utils.ipaddr('address') }} {{ loopback_ipv4 | ansible.utils.ipaddr('netmask') }}
{% for p in prefixes | sort(attribute='prefix') %}
{% set p_state = 'no ' if p.state | default('present') == 'absent' else '' %}
 {{ p_state }}ipv4 address {{ p.prefix | ansible.utils.ipaddr('address') }} {{ p.prefix | ansible.utils.ipaddr('netmask') }} secondary
{% endfor %}
 no shutdown
!

{# P2P Interface Settings #}
{% if interfaces is defined %}
{% for iface in interfaces %}
interface {{ iface.name }}
 description {{ iface.description }}
{% if ip_unumbered | default(false) | bool %}
 ipv4 unnumbered Loopback0
{% else %}
 ipv4 address {{ iface.ipv4_address | ansible.utils.ipaddr('address') }} {{ iface.ipv4_address | ansible.utils.ipaddr('netmask') }}
{% endif %}
 no shutdown
!
{% endfor %}
{% endif %}

{# Static Routes (Discards map to Null0) #}
{% if static_routes is defined and static_routes | length > 0 %}
router static
 address-family ipv4 unicast
{% for route in static_routes | sort(attribute='prefix') %}
{% set action_suffix = ' Null0' if route.action == 'discard' else '' %}
{% set state_prefix = 'no ' if route.state | default('present') == 'absent' else '' %}
  {{ state_prefix }}{{ route.prefix }}{{ action_suffix }}
{% endfor %}
!
{% endif %}

{#
Optional use of IP unnumbered.
Mapping all point-to-point interfaces to the exact same loopback unit (e.g., lo0.0)
#}
